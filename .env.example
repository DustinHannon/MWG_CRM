# MWG CRM environment variables.
# Copy this file to `.env.local` for local development. Never commit `.env.local`.
# Production values live in the Vercel project (set via `vercel env`).

# ---- Auth.js v5 ----
# 32-byte base64 secret. Generate with: openssl rand -base64 32
AUTH_SECRET=
# Auth.js trusts the X-Forwarded-* headers from Vercel.
AUTH_TRUST_HOST=true

# ---- Microsoft Entra ID (single-tenant: ae128315-4515-4382-89e8-094e98d313bc) ----
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/ae128315-4515-4382-89e8-094e98d313bc/v2.0

# ---- Database (Supabase Postgres) ----
# Pooled (transaction mode, port 6543). Use for runtime queries.
POSTGRES_URL=
# Direct (port 5432). Use for `drizzle-kit generate`.
POSTGRES_URL_NON_POOLING=

# ---- Vercel Blob ----
# Set automatically by `vercel blob create-store --yes`.
BLOB_READ_WRITE_TOKEN=

# ---- App ----
APP_NAME=MWG CRM
ALLOWED_EMAIL_DOMAINS=morganwhite.com,mwadmin.com,mwgdirect.com,mwgemployerservices.com,mwgbrokerservices.com,mwgadministrators.com,morganwhiteintl.com,mestmaker.com,mwg401k.com,mwgpayrollsolutions.com
DEFAULT_TIMEZONE=America/Chicago

# ---- Phase 23 — Dynamics 365 CRM import (one-way pull, human-in-the-loop) ----
# Q-01 decision: REUSE the existing `MWG-D365-Sync-OpenWebUI` Entra app
# credentials (already used by the Python d365_sync.py v2 nightly job to feed
# Open WebUI's RAG knowledge base). Same client_id / client_secret values.
# The existing app's Security Role is System Administrator; for Phase 23's
# one-way pull this is over-privileged but accepted per Q-01.
D365_TENANT_ID=ae128315-4515-4382-89e8-094e98d313bc
D365_CLIENT_ID=
D365_CLIENT_SECRET=
D365_BASE_URL=https://mwgroup.crm.dynamics.com
D365_API_VERSION=9.2
# OData server max — request page size for individual D365 fetches.
D365_DEFAULT_PAGE_SIZE=5000
# User-visible review batch size — locked by Phase 23 brief; do not change
# without explicit approval.
D365_IMPORT_BATCH_SIZE=100
# Look-back tolerance in hours when delta-fetching by `modifiedon`.
D365_TIMESTAMP_TOLERANCE_HOURS=24
# Q-05 decision: when a D365 lead's owner cannot be resolved (no Entra
# match, no JIT path), assign to this user's email. Must be an existing
# mwg-crm user. Default is dustin.hannon@morganwhite.com (Dustin owns
# unattributed imports per the user instruction).
D365_DEFAULT_OWNER_EMAIL=dustin.hannon@morganwhite.com

# ---- Supabase service role (Phase 23 Realtime broadcasts) ----
# Required by `src/lib/d365/realtime-broadcast.ts` to publish
# `d365-import-run:<runId>` channel events from server-side code. If
# unset, the live-progress panel falls back to 5-second polling against
# /api/admin/d365-import/runs/<runId>/status — functional but slower.
# Pull from Supabase project Settings → API → service_role key.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Canonical host + legacy redirect ----
# Canonical production hostname. `src/proxy.ts` reads this to redirect
# any request whose `Host` header matches LEGACY_VERCEL_HOST. Defaults
# baked into env schema; override only if the canonical hostname moves.
NEXT_PUBLIC_APP_URL=https://crm.morganwhite.com
NEXT_PUBLIC_CANONICAL_HOST=crm.morganwhite.com
LEGACY_VERCEL_HOST=mwg-crm.vercel.app
