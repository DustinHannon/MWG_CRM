# Phase 29 §7 — Configuration for the ClickDimensions extraction script.
#
# Copy to `.env` and fill in. `.env` is gitignored — keep secrets local.

# D365 / ClickDimensions tenant base URL.
CD_BASE_URL=https://mwgroup.crm.dynamics.com

# Optional — landing path inside the tenant. The auth flow navigates
# CD_BASE_URL by default; if the templates list lives at a deep route
# you can pin it here to short-circuit the operator hand-off.
CD_TEMPLATES_URL=

# MWG CRM API base URL + key. Generate the key at
# https://crm.morganwhite.com/admin/api-keys with scope
# `marketing.migrations.api` (or `admin`).
MWG_API_BASE=https://crm.morganwhite.com/api/v1
MWG_API_KEY=mwg_live_xxx

# Sequential extraction concurrency. Phase 29 locked default = 1.
CD_EXTRACTION_CONCURRENCY=1

# Per-template timeout, milliseconds. Locked default = 60000.
CD_EXTRACTION_TIMEOUT_MS=60000

# Storage path for the persisted auth state. Keep this in the script
# directory; do not commit.
STORAGE_STATE_PATH=storage.json

# Local progress file — survives restarts. Idempotency at the server is
# keyed by cd_template_id so this file's main job is to skip already-
# processed rows in the same session.
EXTRACTION_STATE_PATH=extraction-state.json
