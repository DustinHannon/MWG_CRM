{
  "crons": [
    { "path": "/api/cron/tasks-due-today", "schedule": "0 14 * * *" },
    { "path": "/api/cron/saved-search-digest", "schedule": "0 14 * * *" },
    { "path": "/api/cron/rescore-leads", "schedule": "0 9 * * *" },
    { "path": "/api/cron/purge-archived", "schedule": "0 10 * * *" },
    { "path": "/api/cron/retention-prune", "schedule": "0 8 * * *" },
    { "path": "/api/cron/marketing-sync-suppressions", "schedule": "0 * * * *" },
    { "path": "/api/cron/marketing-process-scheduled-campaigns", "schedule": "*/5 * * * *" },
    { "path": "/api/cron/marketing-recover-stuck-sending", "schedule": "*/15 * * * *" },
    { "path": "/api/cron/marketing-list-refresh", "schedule": "0 8 * * *" },
    { "path": "/api/cron/process-jobs", "schedule": "*/5 * * * *" },
    { "path": "/api/cron/scrape-supabase-metrics", "schedule": "* * * * *" },
    { "path": "/api/cron/prune-supabase-metrics", "schedule": "0 3 * * *" }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "mwg-crm.vercel.app" }],
      "destination": "https://crm.morganwhite.com/:path*",
      "permanent": true
    }
  ]
}
