.env*.local

# Markdown / documentation — local-only.
# Only README.md is tracked. Phase plans, audits, reports, design notes, governance
# rules, architecture docs, and Claude-Code operational context all stay out of GitHub.
# STANDARDS.md and CLAUDE.md live locally in the working tree; agents read them at
# session start. No AI-related MD files are tracked in version control.
/*.md
!/README.md
docs/*
docs/**/
/*.scratch.md
/.scratch/
/screenshottemp/
/.phase8-evidence/

# Tests — Playwright e2e suites are versioned; other tests/ scratch stays local.
# Playwright suite runs against production from a developer's machine
# with PLAYWRIGHT_LOGIN_* env vars; credentials are env-only, never in code.
# Test runtime artifacts (reports, results, cache) remain local-only.
tests/*
!tests/e2e/
tests/e2e/.auth/
tests/e2e/**/*.json
tests/e2e/**/*.png
tests/e2e/**/*.webm
tests/e2e/**/*.zip
tests/e2e/**/*.md
playwright-report/
playwright/.cache/
.env.test
.env.test.local
test-results/
.phase16/

# Phase 23 — local-only D365 import recency fixture script.
# Runs against production with D365_CLIENT_SECRET; output drops to .tmp/.
src/scripts/phase23/

# Local-only tooling artifacts
.semgrep/
tools/clickdimensions-migration/
