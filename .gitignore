# Markdown / documentation — local-only.
# Only README.md and docs/STANDARDS.md are tracked. Phase plans, audits, reports,
# design notes, and other architecture docs all stay out of GitHub.
# docs/STANDARDS.md is the versioned source of truth for binding engineering rules;
# CLAUDE.md is local-only Claude-Code operational context that cross-references it.
/*.md
!/README.md
docs/*
docs/**/
!docs/STANDARDS.md
/*.scratch.md
/.scratch/
/screenshottemp/
/.phase8-evidence/

# Tests — local-only.
# Playwright suite runs against production from a developer's machine
# with PLAYWRIGHT_LOGIN_* env vars; not part of the GitHub repo.
tests/
playwright-report/
playwright/.cache/
.env.test
.env.test.local
test-results/
.phase16/

